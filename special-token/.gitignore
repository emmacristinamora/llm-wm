# runs
data/runs/*
!data/runs/runs_summary.jsonl

# allow run directories themselves
!data/runs/*/

# ignore everything inside each run directory
data/runs/*/*

# then re-allow only the two files we want
!data/runs/*/run_summary.json
!data/runs/*/special_token_embeddings.pt